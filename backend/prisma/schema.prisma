// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model user {
  id          String    @id @default(cuid())
  email       String    @unique
  password    String
  role        user_role @default(AGENT)
  name        String
  fields      field[]
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
}

enum user_role {
  ADMIN
  AGENT
}

model field {
  id                String        @id @default(cuid())
  name              String
  crop_type         String
  current_stage     plant_status  @default(PLANTED)
  planting_date     DateTime
  notes             String[]
  assigned_agent_id String?
  user              user?         @relation(fields: [assigned_agent_id], references: [id], onDelete: SetNull)
  created_at        DateTime      @default(now())
  updated_at        DateTime      @updatedAt
}



enum plant_status {
  PLANTED
  GROWING
  READY
  HARVESTED
}
